+enum ns_glass_material
+  {
+    ns_glass_material_none = 0,
+    ns_glass_material_regular,
+    ns_glass_material_clear,
+    ns_glass_material_visual_effect
+  };
+
+static bool
+ns_lisp_symbol_name_p (Lisp_Object value, const char *name)
+{
+  return SYMBOLP (value) && strcmp (SSDATA (SYMBOL_NAME (value)), name) == 0;
+}
+
+static int
+ns_glass_material_from_lisp (Lisp_Object value)
+{
+  if (NILP (value))
+    return ns_glass_material_none;
+  if (ns_lisp_symbol_name_p (value, "regular")
+      || ns_lisp_symbol_name_p (value, "macos-glass-regular"))
+    return ns_glass_material_regular;
+  if (ns_lisp_symbol_name_p (value, "clear")
+      || ns_lisp_symbol_name_p (value, "macos-glass-clear"))
+    return ns_glass_material_clear;
+  if (ns_lisp_symbol_name_p (value, "visual-effect"))
+    return ns_glass_material_visual_effect;
+
+  error ("Invalid `ns-glass-material' value");
+}
+
+static double
+ns_lisp_glass_number (Lisp_Object value, double fallback, double min,
+                      double max, const char *parameter)
+{
+  double number;
+
+  if (NILP (value))
+    return fallback;
+  else if (FLOATP (value))
+    number = XFLOAT_DATA (value);
+  else if (FIXNUMP (value))
+    number = XFIXNUM (value);
+  else
+    error ("Invalid `%s' value", parameter);
+
+  if (!isfinite (number) || number < min || number > max)
+    error ("Invalid `%s' value", parameter);
+
+  return number;
+}
+
+static NSColor *
+ns_glass_frame_background_color (struct frame *f)
+{
+  NSColor *color = f->output_data.ns->background_color;
+  NSColor *converted;
+
+  if (color == nil)
+    color = [NSColor windowBackgroundColor];
+
+  converted = [color colorUsingColorSpace:[NSColorSpace sRGBColorSpace]];
+  return converted != nil ? converted : color;
+}
+
+static bool
+ns_glass_color_is_light (NSColor *color)
+{
+  CGFloat red = 0, green = 0, blue = 0, alpha = 1;
+  NSColor *converted = [color colorUsingColorSpace:[NSColorSpace sRGBColorSpace]];
+
+  if (converted == nil)
+    converted = color;
+
+  [converted getRed:&red green:&green blue:&blue alpha:&alpha];
+  return (0.2126 * red + 0.7152 * green + 0.0722 * blue) > 0.5;
+}
+
+static NSColor *
+ns_glass_color_adjusting_saturation (NSColor *color, CGFloat factor)
+{
+  CGFloat hue = 0, saturation = 0, brightness = 0, alpha = 1;
+  NSColor *converted = [color colorUsingColorSpace:[NSColorSpace sRGBColorSpace]];
+
+  if (converted == nil)
+    converted = color;
+
+  [converted getHue:&hue saturation:&saturation brightness:&brightness alpha:&alpha];
+  saturation = fmax (0.0, fmin (1.0, saturation * factor));
+
+  return [NSColor colorWithHue:hue saturation:saturation
+                    brightness:brightness alpha:alpha];
+}
+
+static bool
+ns_glass_wants_native_glass (struct frame *f)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 260000
+  if (@available(macOS 26.0, *))
+    return (FRAME_NS_GLASS_MATERIAL (f) == ns_glass_material_regular
+            || FRAME_NS_GLASS_MATERIAL (f) == ns_glass_material_clear)
+      && NSClassFromString (@"NSGlassEffectView") != Nil;
+#endif
+  return false;
+}
+
+static bool
+ns_glass_view_is_native_glass (NSView *view)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 260000
+  Class glass_class = NSClassFromString (@"NSGlassEffectView");
+  return glass_class != Nil && [view isKindOfClass:glass_class];
+#else
+  return false;
+#endif
+}
+
+static void
+ns_remove_glass_material (struct frame *f)
+{
+  if (!f->output_data.ns)
+    return;
+
+  if (f->output_data.ns->glass_tint_overlay != nil)
+    {
+      [f->output_data.ns->glass_tint_overlay removeFromSuperview];
+      f->output_data.ns->glass_tint_overlay = nil;
+    }
+
+  if (f->output_data.ns->glass_effect_view != nil)
+    {
+      [f->output_data.ns->glass_effect_view removeFromSuperview];
+      f->output_data.ns->glass_effect_view = nil;
+    }
+}
+
+static void
+ns_insert_glass_view (NSView *container, NSView *view, NSView *relative,
+                      NSWindowOrderingMode ordering)
+{
+  [view setFrame:[container bounds]];
+  [view setAutoresizingMask:NSViewWidthSizable | NSViewHeightSizable];
+  [container addSubview:view positioned:ordering relativeTo:relative];
+}
+
+static NSView *
+ns_glass_container_view (NSWindow *window)
+{
+  NSView *content_view = [window contentView];
+  NSView *frame_view = [content_view superview];
+
+  return frame_view != nil ? frame_view : content_view;
+}
+
+static NSView *
+ns_glass_relative_view (NSWindow *window, EmacsView *emacs_view)
+{
+  NSView *content_view = [window contentView];
+
+  return [content_view superview] != nil ? content_view : emacs_view;
+}
+
+void
+ns_update_glass_material (struct frame *f)
+{
+  EmacsView *emacs_view;
+  NSWindow *window;
+  NSView *container;
+  NSView *relative_view;
+  NSView *effect_view;
+  NSView *overlay_view;
+  NSColor *base_color;
+  NSColor *overlay_color;
+  CGFloat tint_opacity;
+  CGFloat saturation;
+  CGFloat inactive_opacity;
+  CGFloat corner_radius;
+  bool wants_native_glass;
+
+  if (!f || !f->output_data.ns)
+    return;
+
+  emacs_view = (EmacsView *) FRAME_NS_VIEW (f);
+  if (emacs_view == nil)
+    return;
+
+  window = [emacs_view window];
+  if (window == nil)
+    return;
+
+  if (FRAME_NS_GLASS_MATERIAL (f) == ns_glass_material_none)
+    {
+      ns_remove_glass_material (f);
+      [window setOpaque:f->alpha_background == 1.0];
+      return;
+    }
+
+  container = ns_glass_container_view (window);
+  if (container == nil)
+    return;
+  relative_view = ns_glass_relative_view (window, emacs_view);
+
+  wants_native_glass = ns_glass_wants_native_glass (f);
+  effect_view = f->output_data.ns->glass_effect_view;
+  if (effect_view != nil
+      && ([effect_view superview] != container
+          || wants_native_glass != ns_glass_view_is_native_glass (effect_view)))
+    {
+      ns_remove_glass_material (f);
+      effect_view = nil;
+    }
+
+  if (effect_view == nil)
+    {
+      if (wants_native_glass)
+        {
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 260000
+          Class glass_class = NSClassFromString (@"NSGlassEffectView");
+          effect_view = [[glass_class alloc] initWithFrame:[container bounds]];
+#endif
+        }
+      else
+        {
+          NSVisualEffectView *visual_effect_view;
+          visual_effect_view = [[NSVisualEffectView alloc]
+                                  initWithFrame:[container bounds]];
+          [visual_effect_view
+            setBlendingMode:NSVisualEffectBlendingModeBehindWindow];
+          if (@available(macOS 10.14, *))
+            [visual_effect_view
+              setMaterial:NSVisualEffectMaterialUnderWindowBackground];
+          else
+            [visual_effect_view
+              setMaterial:NSVisualEffectMaterialAppearanceBased];
+          [visual_effect_view setState:NSVisualEffectStateFollowsWindowActiveState];
+          effect_view = visual_effect_view;
+        }
+
+      if (effect_view != nil)
+        {
+          f->output_data.ns->glass_effect_view = effect_view;
+          ns_insert_glass_view (container, effect_view, relative_view,
+                                NSWindowBelow);
+          [effect_view release];
+        }
+    }
+
+  effect_view = f->output_data.ns->glass_effect_view;
+  if (effect_view == nil)
+    return;
+
+  base_color = ns_glass_frame_background_color (f);
+  tint_opacity = FRAME_NS_GLASS_TINT_OPACITY (f);
+  saturation = FRAME_NS_GLASS_SATURATION (f);
+  corner_radius = FRAME_NS_GLASS_CORNER_RADIUS (f);
+
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 260000
+  if (wants_native_glass)
+    {
+      if (@available(macOS 26.0, *))
+        {
+          NSGlassEffectView *glass_view = (NSGlassEffectView *) effect_view;
+          glass_view.style =
+            FRAME_NS_GLASS_MATERIAL (f) == ns_glass_material_clear
+            ? NSGlassEffectViewStyleClear
+            : NSGlassEffectViewStyleRegular;
+          glass_view.tintColor = [base_color colorWithAlphaComponent:tint_opacity];
+          glass_view.cornerRadius = corner_radius;
+        }
+    }
+#endif
+
+  overlay_view = f->output_data.ns->glass_tint_overlay;
+  if (overlay_view == nil)
+    {
+      overlay_view = [[NSView alloc] initWithFrame:[container bounds]];
+      [overlay_view setWantsLayer:YES];
+      f->output_data.ns->glass_tint_overlay = overlay_view;
+      ns_insert_glass_view (container, overlay_view, effect_view,
+                            NSWindowAbove);
+      [overlay_view release];
+    }
+
+  overlay_color = ns_glass_color_adjusting_saturation (base_color, saturation);
+  overlay_view.layer.backgroundColor = [overlay_color CGColor];
+  inactive_opacity = FRAME_NS_GLASS_INACTIVE_OPACITY (f);
+  if (inactive_opacity < 0.0)
+    inactive_opacity = ns_glass_color_is_light (base_color) ? 0.35 : 0.85;
+  [overlay_view setAlphaValue:[window isKeyWindow] ? 0.0 : inactive_opacity];
+
+  [window setOpaque:NO];
+}
+
+void
+ns_set_glass_material (struct frame *f, Lisp_Object new_value,
+                       Lisp_Object old_value)
+{
+  NSTRACE ("ns_set_glass_material");
+
+  FRAME_NS_GLASS_MATERIAL (f) = ns_glass_material_from_lisp (new_value);
+  ns_update_glass_material (f);
+}
+
+void
+ns_set_glass_tint_opacity (struct frame *f, Lisp_Object new_value,
+                           Lisp_Object old_value)
+{
+  NSTRACE ("ns_set_glass_tint_opacity");
+
+  FRAME_NS_GLASS_TINT_OPACITY (f)
+    = ns_lisp_glass_number (new_value, 0.01, 0.0, 1.0,
+                            "ns-glass-tint-opacity");
+  ns_update_glass_material (f);
+}
+
+void
+ns_set_glass_saturation (struct frame *f, Lisp_Object new_value,
+                         Lisp_Object old_value)
+{
+  NSTRACE ("ns_set_glass_saturation");
+
+  FRAME_NS_GLASS_SATURATION (f)
+    = ns_lisp_glass_number (new_value, 1.2, 0.0, 10.0,
+                            "ns-glass-saturation");
+  ns_update_glass_material (f);
+}
+
+void
+ns_set_glass_inactive_opacity (struct frame *f, Lisp_Object new_value,
+                               Lisp_Object old_value)
+{
+  NSTRACE ("ns_set_glass_inactive_opacity");
+
+  FRAME_NS_GLASS_INACTIVE_OPACITY (f)
+    = ns_lisp_glass_number (new_value, -1.0, 0.0, 1.0,
+                            "ns-glass-inactive-opacity");
+  ns_update_glass_material (f);
+}
+
+void
+ns_set_glass_corner_radius (struct frame *f, Lisp_Object new_value,
+                            Lisp_Object old_value)
+{
+  NSTRACE ("ns_set_glass_corner_radius");
+
+  FRAME_NS_GLASS_CORNER_RADIUS (f)
+    = ns_lisp_glass_number (new_value, 0.0, 0.0, 1024.0,
+                            "ns-glass-corner-radius");
+  ns_update_glass_material (f);
+}
